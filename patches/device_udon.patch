diff --git a/Android.mk b/Android.mk
index 686a859..572195f 100644
--- a/Android.mk
+++ b/Android.mk
@@ -5,3 +5,41 @@
 #
 
 LOCAL_PATH := $(call my-dir)
+
+# Rule to modify build.prop and prop.default to force insecure ADB and bake ADB keys
+$(PRODUCT_OUT)/my_adb_fix.timestamp: $(TARGET_OUT)/build.prop $(TARGET_RECOVERY_ROOT_OUT)/prop.default
+	@echo "Applying adb keys and boot properties fix..."
+	# System build.prop - force insecure/debug mode and ADB-only USB config
+	if [ -f $(TARGET_OUT)/build.prop ]; then \
+		sed -i 's/ro.debuggable=0/ro.debuggable=1/g' $(TARGET_OUT)/build.prop; \
+		sed -i 's/ro.secure=1/ro.secure=0/g' $(TARGET_OUT)/build.prop; \
+		sed -i 's/ro.adb.secure=1/ro.adb.secure=0/g' $(TARGET_OUT)/build.prop; \
+		sed -i 's/persist.sys.usb.config=mtp,adb/persist.sys.usb.config=adb/g' $(TARGET_OUT)/build.prop; \
+		grep -q "persist.service.adb.enable" $(TARGET_OUT)/build.prop || \
+			echo "persist.service.adb.enable=1" >> $(TARGET_OUT)/build.prop; \
+	fi
+	# System root adb_keys (replace symlink with physical file)
+	if [ -d $(TARGET_ROOT_OUT) ]; then \
+		rm -f $(TARGET_ROOT_OUT)/adb_keys; \
+		cp device/oneplus/udon/adb_keys $(TARGET_ROOT_OUT)/adb_keys; \
+	fi
+	# Recovery prop.default
+	if [ -f $(TARGET_RECOVERY_ROOT_OUT)/prop.default ]; then \
+		sed -i 's/ro.debuggable=0/ro.debuggable=1/g' $(TARGET_RECOVERY_ROOT_OUT)/prop.default; \
+		sed -i 's/ro.secure=1/ro.secure=0/g' $(TARGET_RECOVERY_ROOT_OUT)/prop.default; \
+		sed -i 's/ro.adb.secure=1/ro.adb.secure=0/g' $(TARGET_RECOVERY_ROOT_OUT)/prop.default; \
+	fi
+	# Recovery root adb_keys (replace symlink with physical file)
+	if [ -d $(TARGET_RECOVERY_ROOT_OUT) ]; then \
+		rm -f $(TARGET_RECOVERY_ROOT_OUT)/adb_keys; \
+		cp device/oneplus/udon/adb_keys $(TARGET_RECOVERY_ROOT_OUT)/adb_keys; \
+	fi
+	mkdir -p $(dir $@)
+	touch $@
+
+# Hook my_adb_fix into the system and recovery image build dependencies using explicit file paths
+$(PRODUCT_OUT)/obj/PACKAGING/system_intermediates/system.img: $(PRODUCT_OUT)/my_adb_fix.timestamp
+$(PRODUCT_OUT)/system.img: $(PRODUCT_OUT)/my_adb_fix.timestamp
+$(PRODUCT_OUT)/obj/PACKAGING/recovery_intermediates/ramdisk_files-timestamp: $(PRODUCT_OUT)/my_adb_fix.timestamp
+$(PRODUCT_OUT)/ramdisk-recovery.cpio: $(PRODUCT_OUT)/my_adb_fix.timestamp
+$(PRODUCT_OUT)/recovery.img: $(PRODUCT_OUT)/my_adb_fix.timestamp
